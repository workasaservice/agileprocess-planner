# Persistence mode: json (default) or postgres
PERSISTENCE_MODE=json

# Neon / Postgres connection strings
# Prefer pooled URL in serverless environments
DATABASE_URL_POOLED=
DATABASE_URL=

# Optional DB tuning
DB_MAX_CONNECTIONS=10
DB_IDLE_TIMEOUT_MS=30000
DB_SSL=true

# Neon MCP authentication token for https://mcp.neon.tech/mcp
# Obtain from: https://console.neon.tech -> Account -> API Keys
# This replaces direct Postgres connection (PERSISTENCE_MODE=postgres requires MCP-only enforcement)
NEON_MCP_API_KEY=

# JSON migration control: defaults to false to avoid importing secrets.
INCLUDE_SENSITIVE_JSON=false
