# Persistence mode: json or postgres (recommended)
# postgres mode uses Neon database for config data (users, roles, capacity, projects)
# json mode uses local config/*.json files (legacy, for development)
PERSISTENCE_MODE=postgres

# Neon / Postgres connection strings
# Prefer pooled URL in serverless environments
DATABASE_URL_POOLED=
DATABASE_URL=

# Optional DB tuning
DB_MAX_CONNECTIONS=10
DB_IDLE_TIMEOUT_MS=30000
DB_SSL=true

# Neon MCP authentication token for https://mcp.neon.tech/mcp
# Obtain from: https://console.neon.tech -> Account -> API Keys
# This replaces direct Postgres connection (PERSISTENCE_MODE=postgres requires MCP-only enforcement)
NEON_MCP_API_KEY=

# Neon project and branch IDs (optional, defaults to production)
# Get from: https://console.neon.tech -> Your Project -> Settings
NEON_PROJECT_ID=super-butterfly-14628322
NEON_BRANCH_ID=br-muddy-fog-a88uzi0y

# JSON migration control: defaults to false to avoid importing secrets.
INCLUDE_SENSITIVE_JSON=false

# Azure DevOps Authentication
# Choose one of two methods: "pat" or "service_principal"

# Method 1: Personal Access Token (Legacy - will be deprecated)
# AZURE_DEVOPS_AUTH_TYPE=pat
# AZURE_DEVOPS_PAT=your-pat-token-here

# Method 2: Service Principal (Recommended - secure, no expiration)
# After setting up in Azure Portal (see AZURE_SERVICE_PRINCIPAL_SETUP.md):
AZURE_DEVOPS_AUTH_TYPE=service_principal
AZURE_DEVOPS_TENANT_ID=your-tenant-id-here
AZURE_DEVOPS_CLIENT_ID=your-client-id-here
AZURE_DEVOPS_CLIENT_SECRET=your-client-secret-here

# Azure DevOps Organization Settings (required for both methods)
AZURE_DEVOPS_ORG=your-organization-name
AZURE_DEVOPS_PROJECT=your-project-name
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/your-organization-name/
